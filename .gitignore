# ============================================================
# MyWorth – Root .gitignore
# Stack: Node/TypeScript backend · Vite + React frontend · SQLite
# ============================================================

# ------ Dependencies ----------------------------------------
node_modules/
.pnp
.pnp.js

# ------ Build outputs ---------------------------------------
dist/
dist-ssr/
build/
out/

# ------ TypeScript ------------------------------------------
*.tsbuildinfo

# ------ Environment & secrets -------------------------------
.env
.env.*
!.env.example

# ------ Database & uploaded data ----------------------------
# The /data folder holds the live SQLite DB and user-uploaded files.
# These are local-only and should never be committed.
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ------ Logs ------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------ OS files --------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------ Editor / IDE ----------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------ Vite / local dev ------------------------------------
*.local
vite.config.ts.timestamp-*

# ------ Misc ------------------------------------------------
scratch/
*.parts
